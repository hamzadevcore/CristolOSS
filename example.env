# ==========================================
# CORE APP SETTINGS
# ==========================================
# The base URL for the frontend application (CORS & Redirects)
APP_BASE_URL="http://localhost:5173"

# Comma-separated list of allowed origins for CORS (e.g. "http://localhost:5173,https://my-app.com")
ALLOWED_ORIGINS="http://localhost:5173"

# Set to "true" to bypass actual Stripe payments and mock database upgrades for testing
TEST_MODE="true"

# Automatically grants this many credits to users upon successful phone verification
FREE_TIER_GRANT_CREDITS="1000"

# Enables detailed logging of prompts and responses to the FinetuningLog table
ENABLE_FINETUNING_LOGS="false"

# Unused/deprecated flag in the code, but present in the file
COST_SAVING_MODE="false"

# ==========================================
# SECURITY & COOKIES
# ==========================================
# Secret used to sign JWT Access/Refresh tokens (CRITICAL: Must not be empty)
JWT_SECRET="your-random-jwt-secret-string"

# Secret used to hash user IP addresses, device IDs, and emails (CRITICAL: Must not be empty)
PEPPER_SECRET="your-random-pepper-string"

# Name of the device tracking cookie
DEVICE_COOKIE_NAME="cristol_device_id"

# Set to "true" or "1" if hosting on HTTPS to ensure cookies are secure
COOKIE_SECURE="false"

# Usually "Lax" or "None" (Use "None" if backend and frontend are on different domains + HTTPS)
COOKIE_SAMESITE="Lax"

# ==========================================
# AI & OPENROUTER
# ==========================================
# Your OpenRouter API Key for generating responses and summaries
OPENROUTER_API_KEY=""

# The model used specifically for background summarization tasks
SUMMARIZATION_MODEL="google/gemma-4-31b-it:free"

# ==========================================
# EMAIL (SMTP)
# ==========================================
# SMTP credentials for sending verification OTPs and account deletion warnings
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
